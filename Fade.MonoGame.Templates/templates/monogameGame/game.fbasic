` Minimal Fade MonoGame starter.
`
` The screen renders ONLY on `sync` — one `sync` per frame.
` Texture id 0 is the built-in 1x1 white pixel, so this runs with no asset
` files. It's invisible at 1x1, so we size the sprite up to 50x50.

px = 320
py = 240

sprite 1, px, py, 0
size sprite 1, 50, 50

DO
    IF upkey()    THEN py = py - 4
    IF downkey()  THEN py = py + 4
    IF leftKey()  THEN px = px - 4
    IF rightKey() THEN px = px + 4

    position sprite 1, px, py
    sync
LOOP
