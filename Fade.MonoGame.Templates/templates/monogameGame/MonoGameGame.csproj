<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>disable</Nullable>
    <!-- Desktop is the default. Build the web (KNI/WebGL) bundle with:
             dotnet publish -p:FadeMonoGamePlatform=Web
         The platform-correct MonoGame/KNI packages + the BROWSER define are
         injected by FadeBasic.MonoGame.Game's build props based on this value. -->
    <!-- MonoGame ships its own entry point (Program.cs launches Game1), so the
         console-style generated Main is suppressed. FadeBasic.Build still emits
         `GeneratedFade` from the <FadeSource>/<FadeCommand> items below. -->
    <FadeGenerateMain>false</FadeGenerateMain>
  </PropertyGroup>
  <ItemGroup>
    <!-- Lib = the built-in commands (FadeMonoGameCommands), and brings the engine
         (Game1 + systems) and the Fade core transitively. (We do NOT reference
         .Game directly: its build props would inject DesktopGL/ImGui too, which
         can't restore from a consumed package's props anyway and just duplicate
         the platform refs below.) Stamped to the monogame release at pack time. -->
    <PackageReference Include="FadeBasic.MonoGame.Lib" Version="0.0.0-LOCAL" />
    <!-- The Fade source compiler that emits `GeneratedFade` from the items
         below rides in transitively: FadeBasic.MonoGame.Game bundles the
         FadeBasic.Build generator under buildTransitive/ and runs it here. So
         there is NO FadeBasic.* version to pin in this template — the core
         build-tooling version is locked to the MonoGame package, matching the
         runtime VM it also ships. -->
    <!-- Built-in command surface available to the .fbasic program. -->
    <FadeCommand Include="FadeBasic.Lib.Standard" FullName="FadeBasic.Lib.Standard.StandardCommands" />
    <FadeCommand Include="Fade.MonoGame.Lib" FullName="Fade.MonoGame.Lib.FadeMonoGameCommands" />
    <!-- Your game. Add more <FadeSource> files as the project grows. -->
    <FadeSource Include="game.fbasic" />
  </ItemGroup>
  <!-- The platform MonoGame package, referenced DIRECTLY. NuGet can't restore a
       PackageReference that a consumed package's build props try to inject, so
       the game owns this. Desktop by default; build the web bundle with
       `dotnet publish -p:FadeMonoGamePlatform=Web` (swaps to KNI/BlazorGL). -->
  <ItemGroup Condition="'$(FadeMonoGamePlatform)' != 'Web'">
    <PackageReference Include="MonoGame.Framework.DesktopGL" Version="3.8.5-preview.4" />
    <PackageReference Include="ImGui.NET" Version="1.91.6.1" />
  </ItemGroup>
  <ItemGroup Condition="'$(FadeMonoGamePlatform)' == 'Web'">
    <PackageReference Include="nkast.Kni.Platform.Blazor.GL" Version="4.2.9001.2" />
  </ItemGroup>
  <!-- Debug desktop only: pulls in the content pipeline so the engine builds +
       hot-reloads your assets in-process (Program.cs registers it via
       Game.Services). Release and Web builds omit this reference and the
       FADE_CONTENT_HOTRELOAD symbol, so they carry no desktop-only pipeline and
       use baked/published content instead. -->
  <ItemGroup Condition="'$(Configuration)' == 'Debug' and '$(FadeMonoGamePlatform)' != 'Web'">
    <PackageReference Include="FadeBasic.MonoGame.Content" Version="0.0.0-LOCAL" />
    <!-- Exposes this project's directory to the engine (GameReloader.GetRoot) so
         the content watcher can locate + rebuild your source assets. Debug only,
         so the build-machine path isn't baked into Release/Web output. -->
    <AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
      <_Parameter1>ProjectDir</_Parameter1>
      <_Parameter2>$(MSBuildProjectDirectory)</_Parameter2>
    </AssemblyAttribute>
  </ItemGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug' and '$(FadeMonoGamePlatform)' != 'Web'">
    <DefineConstants>$(DefineConstants);FADE_CONTENT_HOTRELOAD</DefineConstants>
  </PropertyGroup>
</Project>