<Project>
  <!--
    Auto-imported into projects that reference the FadeBasic.MonoGame.Game
    package directly. It only establishes the platform default:

        $(FadeMonoGamePlatform) = Desktop (default) | Web

    It does NOT inject the platform MonoGame packages. NuGet fixes the restore
    graph before a consumed package's build props are evaluated, so a
    PackageReference added here would never restore — the consuming project must
    reference the platform package (MonoGame.Framework.DesktopGL / ImGui.NET, or
    nkast.Kni.Platform.Blazor.GL) itself. The `dotnet new fadebasic-monogame`
    template does exactly that, switching on $(FadeMonoGamePlatform).
  -->
  <PropertyGroup>
    <FadeMonoGamePlatform Condition="'$(FadeMonoGamePlatform)' == ''">Desktop</FadeMonoGamePlatform>
  </PropertyGroup>
</Project>
